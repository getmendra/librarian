{
	"name": "librarian",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "pnpm run build && varlock-wrangler dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --incremental --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --incremental --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"gen": "varlock-wrangler types",
		"deploy": "varlock-wrangler deploy",
		"deploy:preview": "varlock-wrangler versions upload",
		"cf-typegen": "varlock-wrangler types ./src/worker-configuration.d.ts"
	},
	"packageManager": "pnpm@10.30.1",
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^9.39.2",
		"@internationalized/date": "^3.12.1",
		"@lucide/svelte": "^1.8.0",
		"@sveltejs/adapter-cloudflare": "^7.2.6",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.0.18",
		"bits-ui": "^2.18.0",
		"clsx": "^2.1.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"playwright": "^1.58.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.49.2",
		"svelte-check": "^4.3.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2",
		"wrangler": "^4.67.0"
	},
	"dependencies": {
		"@varlock/1password-plugin": "^0.3.5",
		"@varlock/cloudflare-integration": "^0.1.1",
		"jose": "^6.1.3",
		"runed": "^0.37.1",
		"varlock": "^0.9.1",
		"zod": "^4.3.6"
	}
}
