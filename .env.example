# Iceberg REST Catalog
CATALOG_URI=https://catalog.cloudflarestorage.com/<account>/<bucket>
CATALOG_WAREHOUSE=<warehouse>
NAMESPACE_SUFFIX_ORDER=bronze,silver,gold

# Cloudflare Access
CF_ACCESS_TEAM=myteam
POLICY_AUD=<application-audience-tag>

# CATALOG_TOKEN is a Worker secret — set via `wrangler secret put CATALOG_TOKEN`
